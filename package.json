{
  "name": "agentcarry",
  "version": "0.1.0-acceptance.1",
  "description": "Continue coding tasks across agents with evidence and explicit loss",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "bin": {
    "agentcarry": "dist/cli-main.js"
  },
  "files": [
    "dist/",
    "schema/",
    "docs/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "SECURITY.md",
    "PRIVACY.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dist:check": "tsx scripts/check-dist.ts",
    "typecheck": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm test && npm run build",
    "test": "vitest run --dir test",
    "benchmark:validate": "tsx scripts/validate-benchmark.ts benchmark/fixtures",
    "benchmark:score": "tsx scripts/score-benchmark.ts",
    "benchmark:input": "tsx scripts/build-benchmark-input.ts",
    "benchmark:report": "tsx scripts/aggregate-benchmark.ts",
    "benchmark:collect": "tsx scripts/collect-benchmark-targets.ts",
    "benchmark:review": "tsx scripts/review-benchmark.ts",
    "acceptance:validate": "tsx scripts/external-acceptance.ts validate acceptance/runs",
    "acceptance:report": "tsx scripts/external-acceptance.ts report acceptance/runs",
    "acceptance:check-report": "tsx scripts/external-acceptance.ts report acceptance/runs --check acceptance/REPORT.md",
    "demo:tracer": "npm run build && tsx scripts/demo-tracer.ts",
    "compatibility:check": "tsx scripts/check-compatibility.ts"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
